{
  "name": "@the-railyard/scripts",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "test": "pnpm run test:build && pnpm run test:run",
    "test:build": "tsc -p tsconfig.test.json",
    "test:run": "node .test-dist/tests/map-field-utils.test.js && node .test-dist/tests/update-map-template.integration.test.js && node .test-dist/tests/update-map-listing.integration.test.js && node .test-dist/tests/validation-rules.integration.test.js",
    "validate-publish": "tsx validate-publish.ts",
    "validate-update": "tsx validate-update.ts",
    "create-listing": "tsx create-listing.ts",
    "update-listing": "tsx update-listing.ts",
    "regenerate-indexes": "tsx regenerate-indexes.ts",
    "generate-map-templates": "tsx generate-map-templates.ts",
    "check-map-templates": "tsx generate-map-templates.ts --check",
    "generate:map-templates": "tsx generate-map-templates.ts",
    "check:map-templates": "tsx generate-map-templates.ts --check"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
