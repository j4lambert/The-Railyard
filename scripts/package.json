{
  "name": "@the-railyard/scripts",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "make-announcement": "tsx make-announcement.ts --filename",
    "test": "pnpm run test:build && pnpm run test:run",
    "test:build": "tsc -p tsconfig.test.json",
    "test:run": "node --test .test-dist/tests/*.test.js",
    "test:security-rules": "pnpm run test:build && node --test --test-isolation=none .test-dist/tests/security-rules-fixtures.test.js",
    "validate-publish": "tsx validate-publish.ts",
    "validate-update": "tsx validate-update.ts",
    "create-listing": "tsx create-listing.ts",
    "update-listing": "tsx update-listing.ts",
    "format-manifests": "tsx format-manifests.ts",
    "regenerate-indexes": "tsx regenerate-indexes.ts",
    "generate-registry-analytics": "pnpm run generate-registry-analytics:maps && pnpm run generate-registry-analytics:mods",
    "generate-registry-analytics:maps": "tsx generate-downloads.ts --type map --mode full",
    "generate-registry-analytics:mods": "tsx generate-downloads.ts --type mod --mode full",
    "generate-registry-demand-stats": "tsx generate-map-demand-stats.ts",
    "generate-downloads": "pnpm run generate-registry-analytics",
    "generate-downloads:maps": "pnpm run generate-registry-analytics:maps",
    "generate-downloads:mods": "pnpm run generate-registry-analytics:mods",
    "generate-downloads:maps:download-only": "tsx generate-downloads.ts --type map --mode download-only",
    "generate-downloads:mods:download-only": "tsx generate-downloads.ts --type mod --mode download-only",
    "generate-download-history": "tsx generate-download-history.ts",
    "merge-download-attribution": "tsx merge-download-attribution.ts",
    "backfill-download-attribution": "tsx backfill-download-attribution.ts",
    "reconcile-attributed-downloads": "tsx reconcile-attributed-downloads.ts",
    "analytics": "tsx generate-analytics.ts",
    "generate-map-demand-stats": "pnpm run generate-registry-demand-stats",
    "sync-map-file-sizes": "tsx sync-map-file-sizes.ts",
    "notify-discord": "tsx notify-discord.ts",
    "generate-map-templates": "tsx generate-map-templates.ts",
    "check-map-templates": "tsx generate-map-templates.ts --check",
    "generate:map-templates": "tsx generate-map-templates.ts",
    "check:map-templates": "tsx generate-map-templates.ts --check"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jszip": "^3.10.1",
    "yaml": "^2.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
